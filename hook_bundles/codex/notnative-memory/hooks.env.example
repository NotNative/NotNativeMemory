# NotNativeMemory hook configuration (Codex)
MEMORY_MCP_URL=http://127.0.0.1:9500/mcp

# Authentication.
# Set to a token minted by NNM when the server requires auth.
# Single-user loopback deployments can leave this blank if the server allows
# MEMORY_AUTH_LOCALHOST_BYPASS.
MEMORY_MCP_TOKEN=

# UserPromptSubmit
MEMORY_PROMPT_THRESHOLD=0.45
MEMORY_PROMPT_HIGH_THRESHOLD=0.35
MEMORY_PROMPT_MAX_RESULTS=3
MEMORY_PROMPT_MIN_CHARS=15
MEMORY_PROMPT_RECENT_CHUNKS=12
MEMORY_PROMPT_RECENT_QUERY_CHARS=1200
MEMORY_PROMPT_MAX_CONTEXT_CHARS=3500

# SessionStart
MEMORY_SESSION_MAX_TOKENS=500

# Verbatim capture
MEMORY_VERBATIM_CHUNK_CHARS=800
MEMORY_VERBATIM_OVERLAP_CHARS=200
MEMORY_VERBATIM_FLOOR_CHARS=30
MEMORY_VERBATIM_TOOL_VALUE_CHARS=4000
