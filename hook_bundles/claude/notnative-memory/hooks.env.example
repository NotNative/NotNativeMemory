# NotNativeMemory hook configuration (Claude Code) — EXAMPLE TEMPLATE
#
# Copy to `hooks.env` (or run `python merge_hooks.py <install_path> [mcp_url]`
# to generate it from this template) and fill in the values for your setup.
# `hooks.env` itself is gitignored; this file is the canonical reference for
# the keys each hook reads.

# -- Memory MCP server -----------------------------------------------------

# URL of the NotNativeMemory MCP server. Defaults to 127.0.0.1 (IPv4) when
# generated by the installer — NOT `localhost`, because on Windows `localhost`
# resolves to ::1 (IPv6) first and Docker port publishes (`-p 9500:9500`) bind
# only IPv4 by default, which causes the hook to hang on connect until the
# 10s harness timeout fires. Change to your server's host:port if it runs
# elsewhere.
MEMORY_MCP_URL=http://127.0.0.1:9500/mcp

# Authentication.
# The MCP server requires auth since Phase 5. Two options:
#
#   Option 1 (recommended): mint a Bearer token via the /tokens
#   page in the web GUI or POST /auth/login, and paste it here:
#       MEMORY_MCP_TOKEN=nnm_<lookup>.<secret>
#
#   Option 2 (single-user local only): leave MEMORY_MCP_TOKEN
#   blank and set MEMORY_AUTH_LOCALHOST_BYPASS=1 plus
#   MEMORY_AUTH_LOCALHOST_USER=<username> in the SERVER's .env.
#   Only works when the server binds loopback and the hook runs
#   on the same host.
MEMORY_MCP_TOKEN=

# -- UserPromptSubmit (user_prompt_inject.py) ------------------------------

MEMORY_PROMPT_THRESHOLD=0.45        # similarity floor for normal-importance memories
MEMORY_PROMPT_HIGH_THRESHOLD=0.35   # floor for high/critical importance memories
MEMORY_PROMPT_MAX_RESULTS=3         # max memories injected per turn
MEMORY_PROMPT_MIN_CHARS=15          # skip trivial acknowledgements ("ok", "yes")

# -- SessionStart (session_start.py) --------------------------------------

MEMORY_SESSION_MAX_TOKENS=600       # token budget for session-start memory injection

# -- PreCompact (compact_guard.py) ----------------------------------------

MEMORY_COMPACT_MAX_RESULTS=5        # max critical memories to preserve through compaction

# -- VerbatimCapture (verbatim_capture.py) --------------------------------

CLAUDE_VERBATIM_CAPTURE_TIMEOUT_SECONDS=20
# Timeout for the MCP HTTP write, in seconds. Keep this above first-use
# embedding/model warmup so the client does not disconnect while NNM is still
# successfully storing the chunk.

# -- Stop / TurnAnalysis (turn_analysis.py) -------------------------------
#
# This hook runs an LLM call at the end of EVERY turn to extract learnable
# patterns and detect unfulfilled promises. You MUST configure an LLM
# endpoint or it will exit with a "no model resolved" warning each turn
# (no-op, non-blocking).
#
# STRONG RECOMMENDATION: point this at a local provider (LM Studio /
# Ollama / vLLM). Per-turn analysis is a good fit for a cheap local
# model. Sending it to api.anthropic.com means paying for an extra
# call PER TURN on top of your main session — at Claude Haiku 4.5
# rates (~$1/MTok in, $5/MTok out) this works out to roughly 0.2¢
# per turn, so a 100-turn session is around 20¢. Acceptable but not
# free.

# Option A (recommended) — local OpenAI-compatible endpoint.
# Defaults assume LM Studio on the same host. Change OPENAI_BASE_URL to
# point at a different host (e.g. http://gpu-box:1234/v1), or to Ollama's
# OpenAI-compat endpoint (http://localhost:11434/v1). MEMORY_EXTRACT_MODEL
# is auto-discovered from /v1/models when blank; pin a specific id when
# multiple models are loaded.

OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio
# MEMORY_EXTRACT_MODEL=your-loaded-model-id

# Option B — Anthropic API (cheapest model):
#   Only useful if you authenticate Claude Code with a real ANTHROPIC_API_KEY
#   (not OAuth/Pro/Max — the hook can't read OAuth tokens out of Claude Code's
#   credential store). Defaults to claude-haiku-4-5-20251001. EVERY TURN
#   incurs an extra API call on top of your main session.
#
#   ANTHROPIC_API_KEY=sk-ant-...
#   # MEMORY_EXTRACT_MODEL=claude-haiku-4-5-20251001

# Tuning (apply to either option):
#   MEMORY_EXTRACT_TEMP=0.1            # low temperature = deterministic JSON
#   MEMORY_EXTRACT_TIMEOUT=300         # per-LLM-call timeout in seconds.
#                                       # The hook detaches into a background
#                                       # worker, so this only guards against
#                                       # a stuck socket — not a harness clock.
#   MEMORY_EXTRACT_MAX_RESULTS=5       # max items stored per turn
#   MEMORY_EXTRACT_MIN_LENGTH=30       # x10 = 300 chars combined min before analysis fires

# Scope for analyzer-stored memories. Must be a writable scope: '_global',
# '_domain_<name>', or an absolute path. The server-side default 'general'
# is rejected, so leaving this unset and unresolved would silently fail
# every store. Default '_global' keeps preferences and doctrine
# co-located; switch to '_domain_general' (or another domain) if you
# want analyzer output segregated from user-curated rules.
MEMORY_EXTRACT_PROJECT=_global

# Skip the hidden <think> phase on reasoning-model backends (LM Studio,
# vLLM, llama.cpp Qwen3 templates). Reasoning is wasted compute for a
# classifier prompt and burns the subprocess timeout budget. No-op on
# the Anthropic Messages backend.
MEMORY_EXTRACT_DISABLE_REASONING=1

# -- PreToolUse safety gate (pre_tool_safety.py) --------------------------
#
# Refuses a small set of destructive ops (git push --force, rm -rf /,
# git reset --hard origin/..., DROP DATABASE) by exiting 2 before the
# call dispatches. Disabled by default — flip to 1 to enable.

MEMORY_SAFETY_GATE_ENABLED=0
# MEMORY_SAFETY_GATE_BYPASS=1         # set per-shell to skip the gate once
