{
  "_comment": "Reference snippet showing the shape of NotNativeMemory hook entries written into ~/.claude/settings.json. The installer (merge_hooks.py) is the source of truth — it computes the deployed-script paths at install time. This file is documentation only; nothing reads it programmatically.",
  "_identifier": "notnative-memory",
  "_deploy_dir": "~/.claude/hooks/notnative-memory",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python {{DEPLOY_DIR}}/user_prompt_inject.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python {{DEPLOY_DIR}}/session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python {{DEPLOY_DIR}}/compact_guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python {{DEPLOY_DIR}}/turn_analysis.py",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
