# Secrets & environment
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.venv/
venv/

# Models (downloaded at install)
models/

# Local install state
.install-manifest.json

# Server runtime state (admin bootstrap token, future state artifacts).
# Bind-mounted from the host into the mcp container so operators
# with filesystem access can read the bootstrap token without
# docker-exec'ing into the container.
state/

# Claude Code per-project state (not our shipped claude/ templates)
.claude/

# NotNativeCoder per-project state (not our shipped nnc/ templates)
.nnc/

# Planning docs — local-only scratch; never committed.
# Covers the legacy single-file (docs/PLANNING.md), the prefix-style
# multi-file layout (docs/planning-*.md), and the folder-style layout
# (docs/planning/...) so the convention survives layout changes.
docs/PLANNING.md
docs/planning-*
docs/planning/

# Development-notes: raw installer-run captures, debug shell logs,
# anything of that sort that belongs in the working tree for the
# user but not in git.
docs/Development-notes.txt
docs/dev-*

# IDE & OS
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini
.mcp-server.pid
