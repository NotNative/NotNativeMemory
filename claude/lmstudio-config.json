{
  "memory (http - recommended)": {
    "type": "http",
    "url": "http://{{HOSTNAME}}:9500/mcp"
  },
  "memory (stdio - local only)": {
    "command": "python",
    "args": ["{{INSTALL_PATH}}/server.py", "--mcp"],
    "env": {
      "MEMORY_DB_HOST": "{{DB_HOST}}",
      "MEMORY_DB_PORT": "{{DB_PORT}}",
      "MEMORY_DB_NAME": "notnative_memory",
      "MEMORY_DB_USER": "memory",
      "MEMORY_DB_PASSWORD": "{{DB_PASSWORD}}",
      "MEMORY_MODEL_PATH": "{{INSTALL_PATH}}/models/gte-base-en-v1.5"
    }
  }
}
