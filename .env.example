# NotNativeMemory - Database Configuration
# Copy this file to .env and fill in your values.
# The install script generates this automatically.

# Database connection
# For local Docker: host=localhost, port=5433
# For remote: set to your Postgres host
MEMORY_DB_HOST=localhost
MEMORY_DB_PORT=5433
MEMORY_DB_NAME=notnative_memory
MEMORY_DB_USER=memory
MEMORY_DB_PASSWORD=CHANGE_ME

# Embedding model path (relative to project root)
# Downloaded automatically by the install script
MEMORY_MODEL_PATH=models/gte-base-en-v1.5

# MCP server port (used by Docker compose for host port mapping)
MCP_PORT=9500

# Default project name (used by LM Studio where there is no working directory)
# Leave empty for Claude Code (auto-detects from working directory)
MEMORY_DEFAULT_PROJECT=
